library(readr)
pce_zy_2 <- read_delim("~/Downloads/pce_zy_2.tsv",
delim = "\t", escape_double = FALSE,
trim_ws = TRUE)
View(pce_zy_2)
hist(pce_zy_2$pce_goff)
breaks_vec <- seq(0, 0.02, by = 0.01)
hist(pce_zy_2$pce_goff,
breaks = breaks_vec,
col = "skyblue",
main = "Histogram with custom breaks",
xlab = "Value",
ylab = "Frequency")
breaks_vec <- seq(0, 0.75, by = 0.01)
hist(pce_zy_2$pce_goff,
+      breaks = breaks_vec,
hist(pce_zy_2$pce_goff,breaks = breaks_vec,
+      col = "skyblue",
hist(pce_zy_2$pce_goff,
breaks = breaks_vec,
col = "skyblue",
main = "Histogram with custom breaks",
xlab = "Value",
ylab = "Frequency")
